# Normalisation des fins de ligne
* text=auto

# Fichiers texte avec fins de ligne LF (Unix)
*.sh text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.conf text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Fichiers Windows avec fins de ligne CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Fichiers binaires
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.box binary

# Vagrant
Vagrantfile text eol=lf

# Ansible
*.retry binary
