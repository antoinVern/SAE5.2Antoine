# EditorConfig pour cohérence du code
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{bat,ps1,cmd}]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 100

[Vagrantfile]
indent_size = 2
